#!/usr/bin/env bash
# Pre-commit hook: run cargo fmt + clippy on staged changes.
# Install: cp scripts/pre-commit .git/hooks/pre-commit

set -e

# Only check formatting on staged Rust files
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM -- '*.rs')
if [ -z "$STAGED_RS" ]; then
    exit 0
fi

echo "[pre-commit] checking formatting..."
if ! cargo fmt --all -- --check 2>/dev/null; then
    echo ""
    echo "  Formatting check failed. Run 'cargo fmt --all' and re-stage."
    echo ""
    exit 1
fi

echo "[pre-commit] running clippy..."
if ! cargo clippy --workspace -- -D warnings 2>/dev/null; then
    echo ""
    echo "  Clippy found warnings. Fix them and re-stage."
    echo ""
    exit 1
fi

echo "[pre-commit] ok"
